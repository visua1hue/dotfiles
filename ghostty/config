# Build:
# https://ghostty.org/docs/install/pre#macos

auto-update-channel = tip


# General Adjustments:
# https://ghostty.org/docs/config/reference

shell-integration = zsh
shell-integration-features = no-cursor,ssh-env,ssh-terminfo
copy-on-select = true
confirm-close-surface=false
mouse-hide-while-typing = true
mouse-scroll-multiplier = 4
window-colorspace = display-p3
window-save-state = always
window-padding-y = 10
window-padding-x = 10
adjust-cell-height = -2%
unfocused-split-opacity = 0.5
unfocused-split-fill = 000000
split-divider-color = 3a3a3a

cursor-style = block
cursor-color = cell-foreground
adjust-cursor-thickness = 20
custom-shader = /Users/visualhue/.config/ghostty/shaders/cursor_smear.glsl

theme = Cursor Dark
font-family = JetBrainsMono Nerd Font Mono
font-size = 18

macos-window-shadow = false
macos-icon = xray



# Keybindings:
# https://ghostty.org/docs/config/keybind#modifiers
# https://ghostty.org/docs/config/keybind/reference

keybind = command+r=reload_config
keybind = cmd+backspace=text:\x15
keybind = command+k=clear_screen

keybind = command+left=text:\x01
keybind = command+right=text:\x05
keybind = command+shift+left=esc:b
keybind = command+shift+right=esc:f

keybind = command+down=new_split:down
keybind = command+right=new_split:right

keybind = shift>shift=toggle_command_palette
